# MongoDB Atlas - Substitua com sua URL de conexão
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Servidor
PORT=3333
NODE_ENV=development

# Segurança - OBRIGATÓRIO. Gere um valor aleatório forte (ex: openssl rand -base64 32)
# NUNCA use fallback em produção — a aplicação falhará na inicialização se não estiver definido
JWT_SECRET=sua_chave_secreta_muito_longa_e_segura

# CORS - Origens permitidas (uma ou várias separadas por vírgula)
# Ex: http://localhost:3000 ou http://localhost:3000,https://bikecenter.com.br
CORS_ORIGIN=http://localhost:3000
# Para múltiplas origens em produção:
# CORS_ORIGINS=http://localhost:3000,https://bikecenter.com.br,https://app.bikecenter.com.br

# Seed - Credenciais do admin criado pelo seed (usado apenas em desenvolvimento)
# NÃO use em produção - altere a senha após primeiro login
SEED_ADMIN_EMAIL=admin@bikecenter.com.br
SEED_ADMIN_PASSWORD=SenhaSegura123!

# URL pública da API (para gerar URLs absolutas de imagens de produtos)
API_URL=https://api.bikecenter.com.br
