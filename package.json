{
  "name": "bikecenter",
  "version": "1.0.0",
  "private": true,
  "description": "Ecossistema digital Bike Center - Monorepo",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" run dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:mobile:offline": "pnpm --filter mobile dev:offline",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "@expo/metro-runtime": "5.0.4"
    }
  }
}
